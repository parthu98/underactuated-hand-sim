# Python caches and bytecode
__pycache__/
*.py[cod]
*$py.class

# Python virtual environment (if placed inside)
venv/
.venv/
mujoco_env/

# IDE settings and OS-specific files
.vscode/
.idea/
.DS_Store
Thumbs.db

# MuJoCo logs and temporary physics files
MUJOCO_LOG.TXT
*.log
*.tmp

# SSH keys / secrets — never commit
newid
newid.pub
*.pem
id_rsa*

# Ignore specific output files inside plots/ and logs/ but keep the folders
plots/*
!plots/.gitkeep
logs/*
!logs/.gitkeep

# Generated finger models — rebuilt from config.py on every run
high_fidelity/finger.xml
high_fidelity/_finger_fidelity.xml
gripper/gripper.xml
gripper/load_test.xml
.dual-graph/
.dual-graph-context/
PROJECT_MEMORY.md

# Agent-specific instruction files (kept local, never committed)
AGENTS.md
GEMINI.md
CLAUDE.md
CODEX.md
CONTEXT.md
.github/copilot-instructions.md
